BiomeTemperature: 0.3

BiomeWetness: 0.3

SkyColor: #0d1b8a

WaterColor: #817318

GrassColor: #8dbf79

Grasscolor2: #768c6d

GrassColorIsMultiplier: false

FoliageColor: #6c846b

FoliageColor2: #742d12

FoliageColorIsMultiplier: false

FogColor: #000000

#OLD FogColor: #f0c7aa

FogDensity: 0.0
#OLD FogDensity: 0.01

FogTimeWeight: 0.1

FogRainWeight: 0.25

FogThunderWeight: 0.5

